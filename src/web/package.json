    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keepalive-for-react": "5.0.11",
    "lucide-react": "^1.21.0",
    "motion": "^12.41.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
